# Server Port (default: 3001)
PORT=3001

# OpenAI API Key (required) - get from https://platform.openai.com/api-keys
CHATGPT_API_KEY=""

# OpenAI model (e.g. gpt-4o, gpt-4o-mini, gpt-4-turbo)
OPENAI_MODEL="gpt-4o"

# App URL (used for CORS in production)
APP_URL=""

# News API Keys (optional)
NEWS_API_KEY=""
GNEWS_API_KEY=""

# Reports storage directory (relative or absolute path)
REPORTS_DIR="./data/reports"

# Financial Modeling Prep (free: 250 req/day) - get from https://financialmodelingprep.com/developer
FMP_API_KEY=""

# Finnhub (free: 60 req/min) - get from https://finnhub.io/register
FINNHUB_API_KEY=""

# FRED (free, unlimited) - get from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=""

# Gemini API Key (for Hebrew infographic) - get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
